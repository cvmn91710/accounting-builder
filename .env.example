GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
APP_ENV=development
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8501
ENTRA_SCOPES=User.Read
ENTRA_ADMIN_ROLE=Accounting.Admin
TEMPLATE_PATH_CONSERVATORSHIP=templates/conservatorship_template.xlsx
TEMPLATE_PATH_PROBATE=templates/probate_template.xlsx
TEMPLATE_PATH_TRUST=templates/trust_template.xlsx
TEMPLATE_MAPPING_PATH=templates/template_mapping.json
MAX_FILE_SIZE_MB=50
MAX_SESSION_FILES=50
SQLITE_DB_PATH=data/accounting.db
SKIP_ENTRA_AUTH=1

# If local `streamlit run app/streamlit_app.py` errors with "No module named 'app'",
# set PYTHONPATH to the project root (Dockerfile sets PYTHONPATH=/app for containers).
